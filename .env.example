# ==============================================
# VidyaZen - Environment Variables
# Copy this to .env.local for development
# Add these to Vercel Dashboard for production
# ==============================================

# PostgreSQL Database (use Neon - free at neon.tech)
# 1. Go to https://neon.tech and create a free account
# 2. Create a new project called "vidyazen"
# 3. Copy the connection string and paste here
DATABASE_URL="postgresql://username:password@ep-xxx.us-east-1.aws.neon.tech/vidyazen?sslmode=require"

# NextAuth.js Secret
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-min-32-chars-change-this-NOW"

# App URL
# Development:
NEXTAUTH_URL="http://localhost:3000"
# Production (update this on Vercel):
# NEXTAUTH_URL="https://your-vidyazen-app.vercel.app"
