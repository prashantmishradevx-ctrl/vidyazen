# ==============================================
# VidyaZen - Environment Variables
# Copy this to .env.local for development
# Add these to Vercel Dashboard for production
# ==============================================

# Local MySQL database (XAMPP)
DATABASE_URL="mysql://root:@localhost:3306/vidyazen"

# NextAuth.js Secret
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-min-32-chars-change-this-NOW"

# App URL
# Development:
NEXTAUTH_URL="http://localhost:3000"
# Production (update this on Vercel):
# NEXTAUTH_URL="https://your-vidyazen-app.vercel.app"
